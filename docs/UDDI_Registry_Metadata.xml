<?xml version="1.0" encoding="UTF-8"?>

<uddiRegistration xmlns:uddi="urn:uddi-org:api_v3">

    <uddi:businessEntity businessKey="uddi:globalbooks.com:business:001">
        <uddi:name xml:lang="en">GlobalBooks Inc.</uddi:name>

        <uddi:description xml:lang="en">
            Global online bookseller providing SOAP and REST APIs for
            catalogue lookup, order management, payments, and shipping.
        </uddi:description>

        <uddi:contacts>
            <uddi:contact useType="Technical Support">
                <uddi:personName>SOA Team</uddi:personName>
                <uddi:email useType="support">soa-team@globalbooks.com</uddi:email>
                <uddi:address>
                    <uddi:addressLine>1 Book Lane, Reading, RG1 1AA, UK</uddi:addressLine>
                </uddi:address>
            </uddi:contact>
        </uddi:contacts>

        <uddi:businessServices>

            <uddi:businessService
                serviceKey="uddi:globalbooks.com:service:catalog:v1"
                businessKey="uddi:globalbooks.com:business:001">

                <uddi:name xml:lang="en">CatalogService</uddi:name>
                <uddi:description xml:lang="en">
                    SOAP-based book catalogue service. Provides getBookById,
                    getBookPrice (used in BPEL price-lookup loop), and searchBooks.
                    Secured with WS-Security UsernameToken.
                </uddi:description>

                <uddi:bindingTemplates>
                    <uddi:bindingTemplate
                        bindingKey="uddi:globalbooks.com:binding:catalog:v1:prod">

                        <!-- The endpoint URL -->
                        <uddi:accessPoint useType="endPoint">
                            http://localhost:8080/CatalogService/catalog
                        </uddi:accessPoint>

                        <!-- WSDL reference -->
                        <uddi:tModelInstanceDetails>
                            <uddi:tModelInstanceInfo
                                tModelKey="uddi:globalbooks.com:tmodel:catalog:wsdl:v1">
                                <uddi:instanceDetails>
                                    <uddi:overviewDoc>
                                        <uddi:description>WSDL 1.1 contract for CatalogService</uddi:description>
                                        <uddi:overviewURL useType="wsdlInterface">
                                            http://localhost:8080/CatalogService/catalog?wsdl
                                        </uddi:overviewURL>
                                    </uddi:overviewDoc>
                                </uddi:instanceDetails>
                            </uddi:tModelInstanceInfo>
                        </uddi:tModelInstanceDetails>

                        <!-- Categorisation -->
                        <uddi:categoryBag>
                            <uddi:keyedReference
                                tModelKey="uddi:uddi.org:ubr:categorization:unspsc"
                                keyName="Books"
                                keyValue="55111500" />
                            <uddi:keyedReference
                                tModelKey="uddi:uddi.org:wsdl:types"
                                keyName="portType"
                                keyValue="CatalogPortType" />
                        </uddi:categoryBag>

                    </uddi:bindingTemplate>
                </uddi:bindingTemplates>

                <!-- Version and SLA category bag -->
                <uddi:categoryBag>
                    <uddi:keyedReference
                        tModelKey="uddi:globalbooks.com:tmodel:version"
                        keyName="Service Version"
                        keyValue="1.0" />
                    <uddi:keyedReference
                        tModelKey="uddi:globalbooks.com:tmodel:sla"
                        keyName="Availability SLA"
                        keyValue="99.9%" />
                    <uddi:keyedReference
                        tModelKey="uddi:globalbooks.com:tmodel:sla"
                        keyName="Response Time SLA"
                        keyValue="200ms p95" />
                </uddi:categoryBag>

            </uddi:businessService>

        </uddi:businessServices>

    </uddi:businessEntity>

</uddiRegistration>